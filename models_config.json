{
  "providers": {
    "openai": {
      "api_key_env": "OPENAI_API_KEY",
      "default_model": "gpt-4o",
      "models": {
        "gpt-4o":      "openai/gpt-4o",
        "gpt-4o-mini": "openai/gpt-4o-mini",
        "o1":          "openai/o1",
        "o3":          "openai/o3",
        "o3-mini":     "openai/o3-mini",
        "o4-mini":     "openai/o4-mini"
      }
    },
    "anthropic": {
      "api_key_env": "ANTHROPIC_API_KEY",
      "op_reference": "op://llmkeys/Anthropic/credential",
      "default_model": "sonnet-4.6",
      "models": {
        "opus-4.6":   "anthropic/claude-opus-4-6",
        "sonnet-4.6": "anthropic/claude-sonnet-4-6",
        "haiku-4.5":  "anthropic/claude-haiku-4-5-20251001"
      }
    },
    "gemini": {
      "api_key_env": "GEMINI_API_KEY",
      "op_reference": "op://llmkeys/Gemini/credential",
      "default_model": "gemini-2.5-flash",
      "models": {
        "gemini-2.5-flash":                    "gemini/gemini-2.5-flash",
        "gemini-3.1-pro-preview":              "gemini/gemini-3.1-pro-preview",
        "gemini-3.1-pro-preview-customtools":  "gemini/gemini-3.1-pro-preview-customtools",
        "gemini-3-pro-preview":                "gemini/gemini-3-pro-preview"
      }
    },
    "siliconflow": {
      "api_key_env": "SILICONFLOW_API_KEY",
      "op_reference": "op://llmkeys/SiliconFlow/credential",
      "base_url": "https://api.siliconflow.cn/v1",
      "default_model": "Kimi-K2.5",
      "models": {
        "deepseek-v3":                      "openai/deepseek-ai/DeepSeek-V3",
        "deepseek-r1":                      "openai/deepseek-ai/DeepSeek-R1",
        "Qwen3.5-397B-A17B":               "openai/Qwen/Qwen3.5-397B-A17B",
        "Qwen3-VL-32B":                    "openai/Qwen/Qwen3-VL-32B-Instruct",
        "Qwen2.5-VL-72B":                  "openai/Qwen/Qwen2.5-VL-72B-Instruct",
        "deepseek-vl2":                    "openai/deepseek-ai/deepseek-vl2",
        "Qwen3-Coder-480B-A35B-Instruct":  "openai/Qwen/Qwen3-Coder-480B-A35B-Instruct",
        "QwQ-32B":                          "openai/Qwen/QwQ-32B",
        "Qwen2.5-32B-Instruct":            "openai/Qwen/Qwen2.5-32B-Instruct",
        "Kimi-K2-Instruct-0905":           "openai/moonshotai/Kimi-K2-Instruct-0905",
        "Kimi-K2.5":                        "openai/Pro/moonshotai/Kimi-K2.5",
        "MiniMax-M2.5":                     "openai/Pro/MiniMaxAI/MiniMax-M2.5",
        "GLM-4.6":                          "openai/zai-org/GLM-4.6",
        "SenseVoiceSmall":                  "openai/FunAudioLLM/SenseVoiceSmall"
      }
    },
    "poe": {
      "api_key_env": "POE_API_KEY",
      "op_reference": "op://llmkeys/Poe/credential",
      "default_model": "Claude-Sonnet-4.5",
      "models": {
        "Claude-Opus-4.5":   "poe/Claude-Opus-4.5",
        "Claude-Sonnet-4.5": "poe/Claude-Sonnet-4.5",
        "Claude-Haiku-4.5":  "poe/Claude-Haiku-4.5",
        "Gemini-3-Pro":      "poe/Gemini-3-Pro",
        "GPT-4o":            "poe/GPT-4o",
        "Grok-4":            "poe/Grok-4",
        "Llama-3.1-405B":    "poe/Llama-3.1-405B"
      }
    }
  }
}
